# ====================================
# Mission Control Configuration
# ====================================

# Database path (default: ./mission-control.db)
DATABASE_PATH=./mission-control.db

# ====================================
# OpenClaw Gateway Configuration
# ====================================

# OpenClaw Gateway URL (default: ws://127.0.0.1:18789)
# For remote connections via Tailscale: wss://your-machine.tail12345.ts.net
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789

# OpenClaw Gateway authentication token (required for remote connections)
# Generate with: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# ====================================
# Workspace Configuration
# ====================================

# Mission Control API URL (auto-detected if not set)
# Override for remote access or custom deployments
# MISSION_CONTROL_URL=http://localhost:3000

# Base workspace directory (default: ~/Documents/Shared)
# All Mission Control files are stored here
# WORKSPACE_BASE_PATH=~/Documents/Shared

# Projects directory (default: ~/Documents/Shared/projects)
# Each project gets a unique folder here
# PROJECTS_PATH=~/Documents/Shared/projects

# ====================================
# Agent API Security (Recommended)
# ====================================

# Optional shared token for agent write endpoints:
#   /api/tasks/*/activities (POST)
#   /api/tasks/*/deliverables (POST)
#   /api/tasks/*/subagent (POST)
#   /api/files/upload (POST)
#   /api/files/download (GET)
# If set, clients must send:
#   Authorization: Bearer <token>
# MISSION_CONTROL_AGENT_TOKEN=replace-with-a-long-random-token

# Maximum upload payload size in bytes (default: 1048576 = 1MB)
# MISSION_CONTROL_MAX_UPLOAD_BYTES=1048576

# ====================================
# Codex Mission Planner
# ====================================

# OpenAI API key used by /api/workspaces/{id}/codex
# OPENAI_API_KEY=sk-...

# Planner model (default: codex5.3)
# MISSION_CONTROL_CODEX_MODEL=codex5.3

# ====================================
# Core Runtime (OpenClaw MissionControlServer)
# ====================================

# URL of the core runtime server (default: http://127.0.0.1:4317)
# Telegram messages and other orchestration calls are relayed through this
# CORE_RUNTIME_URL=http://127.0.0.1:4317

# ====================================
# Telegram Control Bridge
# ====================================
# Note: Telegram Bot API calls are relayed through the core runtime.
# Configure TELEGRAM_* env vars on the core runtime process, or use
# the Mission Control Settings UI to store config in app_settings.

# Telegram Bot API token (from @BotFather) — used as fallback for app_settings
# TELEGRAM_BOT_TOKEN=

# Default chat ID for outbound notifications
# TELEGRAM_DEFAULT_CHAT_ID=

# Comma-separated list of additional allowed chat IDs
# TELEGRAM_ALLOWED_CHAT_IDS=

# Secret token for webhook validation (optional, recommended)
# Generate with: openssl rand -hex 16
# TELEGRAM_WEBHOOK_SECRET=

# ====================================
# Security Notes
# ====================================
# 
# NEVER commit this file with real values!
# This is a template - copy to .env.local and configure:
#
#   cp .env.example .env.local
#
# Then edit .env.local with your actual values.
# .env.local is gitignored and will not be committed.
